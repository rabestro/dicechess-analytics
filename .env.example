DATABASE_URL="postgresql+asyncpg://dicechess_user:dicechess_password@localhost:5432/dicechess_analytics"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# --- Authentication & access control (Google OAuth2 + approval workflow) ---
# SECRET_KEY signs the session cookie (HMAC). REQUIRED in production: the app
# refuses to start without it unless MOCK_AUTH=true. Generate a long random value.
SECRET_KEY=""
# MOCK_AUTH=true bypasses Google login and treats every request as a pre-approved
# admin. Local/dev only — never set in production.
MOCK_AUTH="true"
# Google OAuth2 client credentials (from the Google Cloud console). Required when
# MOCK_AUTH is not set. GOOGLE_REDIRECT_URI must match the console configuration
# and point at <api-host>/api/auth/callback.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/callback"
# Where the callback sends the browser after a successful login.
FRONTEND_URL="http://localhost:5173"
# This email is auto-provisioned (and re-promoted on every login) as an approved
# admin — the bootstrap for the very first administrator.
ADMIN_EMAIL=""

# --- Image tags (read by docker-compose.yaml) ---
# Unset => `latest` (fine for local/dev and staging). PIN production to a
# released version so `docker compose pull` cannot drift onto a broken `:latest`
# (issue #117), e.g.:
# API_TAG=v0.1.5
# UI_TAG pins the web image the same way, once the UI repo publishes versions.
